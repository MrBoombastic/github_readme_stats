#!/usr/bin/env bash
set -e

SOLUTION="src/GitHubStats.sln"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}Running pre-commit checks...${NC}"
echo ""

# 1. Secret / sensitive data scan
echo -e "${CYAN}[1/4]${NC} Scanning for secrets..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED_FILES" ]; then
    # Patterns to detect secrets and tokens
    SECRET_PATTERNS=(
        'ghp_[A-Za-z0-9]{36}'                    # GitHub PAT (fine-grained)
        'github_pat_[A-Za-z0-9_]{82}'             # GitHub PAT (new format)
        'gho_[A-Za-z0-9]{36}'                     # GitHub OAuth token
        'ghu_[A-Za-z0-9]{36}'                     # GitHub user-to-server token
        'ghs_[A-Za-z0-9]{36}'                     # GitHub server-to-server token
        'sk-[A-Za-z0-9]{20,}'                     # OpenAI / generic API keys
        'sk-ant-[A-Za-z0-9\-]{80,}'               # Anthropic API keys
        'AKIA[0-9A-Z]{16}'                         # AWS Access Key ID
        'AIza[0-9A-Za-z\-_]{35}'                   # Google API key
        '[0-9a-f]{40}'                             # Generic 40-char hex (git tokens, SHA secrets)
        'xox[bpsar]-[A-Za-z0-9\-]+'               # Slack tokens
        'eyJ[A-Za-z0-9_\-]{20,}\.eyJ[A-Za-z0-9_\-]{20,}\.' # JWT tokens
    )

    # Keywords that suggest secrets in key=value or JSON patterns
    KEYWORD_PATTERNS=(
        '(password|passwd|secret|token|apikey|api_key|api_secret|access_key|private_key|client_secret)\s*[:=]\s*["\x27][^\s"'\'']{8,}'
        'connectionstring\s*[:=]\s*["\x27].*password=.+'
    )

    FOUND_SECRETS=0

    for file in $STAGED_FILES; do
        # Skip binary files and the hook itself
        if ! file "$file" 2>/dev/null | grep -q text; then
            continue
        fi

        STAGED_CONTENT=$(git show ":$file" 2>/dev/null) || continue

        for pattern in "${SECRET_PATTERNS[@]}"; do
            MATCHES=$(echo "$STAGED_CONTENT" | grep -nEo "$pattern" 2>/dev/null || true)
            if [ -n "$MATCHES" ]; then
                # Skip known false positives (placeholder text, examples, empty values)
                FILTERED=$(echo "$MATCHES" | grep -v -E '(example|placeholder|here|TODO|xxxx|0{40}|\.gitignore)' || true)
                if [ -n "$FILTERED" ]; then
                    echo -e "  ${RED}Possible secret in ${file}:${NC}"
                    echo "$FILTERED" | head -3 | while read -r line; do
                        echo -e "    ${RED}> ${line}${NC}"
                    done
                    FOUND_SECRETS=1
                fi
            fi
        done

        for pattern in "${KEYWORD_PATTERNS[@]}"; do
            MATCHES=$(echo "$STAGED_CONTENT" | grep -niE "$pattern" 2>/dev/null || true)
            if [ -n "$MATCHES" ]; then
                FILTERED=$(echo "$MATCHES" | grep -v -iE '(example|placeholder|here|TODO|null|""|\x27\x27|template|\.example)' || true)
                if [ -n "$FILTERED" ]; then
                    echo -e "  ${RED}Possible secret in ${file}:${NC}"
                    echo "$FILTERED" | head -3 | while read -r line; do
                        echo -e "    ${RED}> ${line}${NC}"
                    done
                    FOUND_SECRETS=1
                fi
            fi
        done
    done

    # Check for sensitive file names
    SENSITIVE_FILES=$(echo "$STAGED_FILES" | grep -iE '(\.env$|\.env\.|\.pem$|\.key$|\.pfx$|\.p12$|credentials\.json|secret|\.jks$)' || true)
    if [ -n "$SENSITIVE_FILES" ]; then
        echo -e "  ${RED}Sensitive files staged for commit:${NC}"
        echo "$SENSITIVE_FILES" | while read -r f; do
            echo -e "    ${RED}> ${f}${NC}"
        done
        FOUND_SECRETS=1
    fi

    if [ "$FOUND_SECRETS" -eq 1 ]; then
        echo ""
        echo -e "  ${RED}Commit blocked: potential secrets detected.${NC}"
        echo -e "  If these are intentional (e.g., placeholders), use: git commit --no-verify"
        exit 1
    fi
fi
echo -e "  ${GREEN}No secrets found${NC}"

# 2. Format check (lint)
echo -e "${CYAN}[2/4]${NC} Checking code format..."
if ! dotnet format "$SOLUTION" --verify-no-changes --no-restore --verbosity quiet 2>/dev/null; then
    echo -e "${RED}Format check failed.${NC} Run 'dotnet format $SOLUTION' to fix."
    exit 1
fi
echo -e "  ${GREEN}Format OK${NC}"

# 2. Build
echo -e "${CYAN}[3/4]${NC} Building..."
if ! dotnet build "$SOLUTION" -c Release --nologo -v q --no-restore 2>/dev/null; then
    echo -e "${RED}Build failed.${NC}"
    exit 1
fi
echo -e "  ${GREEN}Build OK${NC}"

# 3. Tests
echo -e "${CYAN}[4/4]${NC} Running tests..."
if ! dotnet test "$SOLUTION" -c Release --no-build --nologo -v q 2>/dev/null; then
    echo -e "${RED}Tests failed.${NC}"
    exit 1
fi
echo -e "  ${GREEN}Tests OK${NC}"

echo ""
echo -e "${GREEN}All pre-commit checks passed.${NC}"
